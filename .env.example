# Runtime connection string for application queries.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/english_os?schema=public"

# Direct connection string for Prisma migrations.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/english_os?schema=public"

# Auth.js secret and GitHub OAuth credentials.
AUTH_SECRET="replace-with-output-of-npx-auth-secret"
AUTH_GITHUB_ID="replace-with-your-github-oauth-app-id"
AUTH_GITHUB_SECRET="replace-with-your-github-oauth-app-secret"

# Server-side AI integration.
OPENAI_API_KEY="replace-with-your-openai-api-key"
